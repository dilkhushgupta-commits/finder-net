# Frontend Environment Configuration
# Copy this to .env.local for development

# API Configuration
# In production via Vercel: /api (proxied to backend)
# In development: Vite proxy handles /api -> http://localhost:5000
VITE_API_URL=/api

# Socket.IO Configuration
# Leave empty in production (uses same origin)
# In development: set to http://localhost:5000 if backend on different port
VITE_SOCKET_URL=

# App Branding
VITE_APP_NAME=Finder-Net
