# ============================================
# Finder-Net Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Server
NODE_ENV=production
PORT=5000

# Supabase (REQUIRED)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT (REQUIRED - generate strong random secrets!)
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_random_64_char_hex
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_generate_another_random_hex

# Client URL (for CORS and emails)
CLIENT_URL=https://your-domain.com

# AI Service (internal docker network URL)
AI_SERVICE_URL=http://ai-service:8000

# Cloudinary (optional - falls back to local /uploads storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (optional - SMTP config for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@your-domain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=5242880
